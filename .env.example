# =============================================================================
# JobPilot Environment Configuration
# Copy to .env and fill in your values
# =============================================================================

# --- Database ---
POSTGRES_USER=jobpilot
POSTGRES_PASSWORD=jobpilot_dev
POSTGRES_DB=jobpilot
DATABASE_URL=postgresql+asyncpg://jobpilot:jobpilot_dev@localhost:5432/jobpilot

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Qdrant ---
QDRANT_URL=http://localhost:6333

# --- Temporal ---
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=jobpilot-tasks

# --- MinIO (Object Storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=jobpilot-resumes
MINIO_SECURE=false

# =============================================================================
# LLM Configuration — pick ONE provider
# =============================================================================
#
# OPTION A: OpenRouter (recommended — one key, access to all models)
#   Get your key at: https://openrouter.ai/keys
#
# OPTION B: Direct OpenAI
#   Set OPENAI_API_KEY and use model names like "gpt-4o"
#
# OPTION C: Direct Anthropic
#   Set ANTHROPIC_API_KEY and use model names like "claude-sonnet-4-20250514"
#
# You can mix providers — LiteLLM routes based on model prefix.
# =============================================================================

# --- Option A: OpenRouter (one key for all models) ---
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Models via OpenRouter (prefix with "openrouter/")
LLM_PRIMARY_MODEL=openrouter/google/gemini-2.5-flash
LLM_FAST_MODEL=openrouter/google/gemini-2.5-flash
LLM_FALLBACK_MODEL=openrouter/anthropic/claude-sonnet-4
EMBEDDING_MODEL=openrouter/openai/text-embedding-3-small

# --- Option B: Direct OpenAI (uncomment to use) ---
# OPENAI_API_KEY=sk-your-openai-key
# LLM_PRIMARY_MODEL=gpt-4o
# LLM_FAST_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small

# --- Option C: Direct Anthropic (uncomment to use) ---
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# LLM_PRIMARY_MODEL=claude-sonnet-4-20250514
# LLM_FAST_MODEL=claude-sonnet-4-20250514

# --- Third-Party APIs (Phase 2+) ---
SERPAPI_KEY=
RAPIDAPI_KEY=
BRIGHTDATA_USERNAME=
BRIGHTDATA_PASSWORD=

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# =============================================================================
# JobPilot Environment Configuration
# Copy to .env and fill in your values
# =============================================================================

# --- Database ---
POSTGRES_USER=jobpilot
POSTGRES_PASSWORD=jobpilot_dev
POSTGRES_DB=jobpilot
DATABASE_URL=postgresql+asyncpg://jobpilot:jobpilot_dev@localhost:5432/jobpilot

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Qdrant ---
QDRANT_URL=http://localhost:6333

# --- Temporal ---
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=jobpilot-tasks

# --- MinIO (Object Storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=jobpilot-resumes
MINIO_SECURE=false

# --- LLM API Keys ---
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# --- LLM Configuration ---
LLM_PRIMARY_MODEL=gpt-4o
LLM_FAST_MODEL=gpt-4o-mini
LLM_FALLBACK_MODEL=claude-sonnet-4-20250514
EMBEDDING_MODEL=text-embedding-3-small

# --- Third-Party APIs (Phase 2+) ---
SERPAPI_KEY=
RAPIDAPI_KEY=
BRIGHTDATA_USERNAME=
BRIGHTDATA_PASSWORD=

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
